{
  "name": "intechroot-be",
  "version": "1.0.0",
  "description": "InTech Root ERP Backend — Node.js + Express + Prisma + Supabase",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "prisma generate",
    "dev": "node --watch server.js",
    "build": "prisma generate && node scripts/check-build.js",
    "start": "node server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:backfill-employee-users": "node scripts/backfill-employee-portal-users.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
